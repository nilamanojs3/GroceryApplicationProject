<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Cross Browser Testing">
	<test thread-count="5" name="Chrome Test">
		<parameter name="browsers" value="chrome"></parameter>
		<classes>
			<class name="testscripts.LoginTest">
				<methods>
					<include
						name="verifyUserLoginwithInvalidUsernameandValidpassword"></include>
				</methods>
			</class>
		</classes>
	</test> <!--
	Test -->

	<test thread-count="5" name="FireFox Test">
		<parameter name="browsers" value="firefox"></parameter>
		<classes>
			<class name="testscripts.LoginTest">
				<methods>
					<include
						name="verifyUserLoginwithInvalidUsernameandValidpassword"></include>
				</methods>
			</class>
		</classes>
	</test> <!--
	Test -->
</suite> <!--
Suite -->
